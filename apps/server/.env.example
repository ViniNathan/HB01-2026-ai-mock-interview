# Backend (Express) — copy to apps/server/.env for local development.
# Frontend (Next.js): see apps/web/.env.example — NEXT_PUBLIC_SERVER_URL must match this server's base URL (ex.: http://localhost:3000).

# Database
# Connection string (PostgreSQL URI). Ex.: postgresql://user:pass@localhost:5432/dbname
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hackathon2026

# Server Configuration
# TCP port number the Express server listens on. Ex.: 3000
PORT=3000

# Allowed CORS origin (full URL of the web app). Ex.: http://localhost:3001
CORS_ORIGIN=http://localhost:3001

# Frontend base URL used in emails (password reset links, etc.). Ex.: http://localhost:3001
FRONTEND_URL=http://localhost:3001

# Runtime environment. Allowed: development | production | test
NODE_ENV=development

# JWT Configuration
# Signing secret for access/refresh tokens (min 32 characters). Ex.: your-super-secret-jwt-key-min-32-chars
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# Access token lifetime (duration string, not seconds). Ex.: 15m, 1h
JWT_EXPIRE_IN=15m

# Refresh token lifetime in seconds. Ex.: 604800 (= 7 days)
REFRESH_EXPIRES=604800

# Reset-password token lifetime (duration string). Ex.: 1h
RESET_PASSWORD_JWT_EXPIRE_IN=1h

# SMTP / Email Configuration
# SMTP server hostname. Ex.: smtp.gmail.com
SMTP_HOST=smtp.gmail.com
# SMTP port (TCP). Ex.: 587 (TLS) or 465 (SSL)
SMTP_PORT=587
# SMTP authentication username (often the sender email). Ex.: your-email@gmail.com
SMTP_USER=your-email@gmail.com
# SMTP password or app-specific password. Ex.: your-app-password
SMTP_PASS=your-app-password
# From address shown in outgoing mail (valid email). Ex.: your-email@gmail.com
MAIL_FROM=your-email@gmail.com

# Rate Limiting
# Time window for rate limiting in milliseconds (default: 15 minutes = 900000)
RATE_LIMIT_WINDOW_MS=900000

# Max requests per window per IP (default: 20)
RATE_LIMIT_MAX=20
