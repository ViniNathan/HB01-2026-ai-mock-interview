# backend (Express) - copy to backend/.env for local development.
# frontend (Next.js): see frontend/.env.example - NEXT_PUBLIC_SERVER_URL must match this server's base URL (ex.: http://localhost:3000).

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hackathon2026

# Server Configuration
PORT=3000
CORS_ORIGIN=http://localhost:3001
FRONTEND_URL=http://localhost:3001
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRE_IN=15m
REFRESH_EXPIRES=604800
RESET_PASSWORD_JWT_EXPIRE_IN=1h

# SMTP / Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
MAIL_FROM=your-email@gmail.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=20
